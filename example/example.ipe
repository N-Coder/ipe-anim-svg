<text layer="theta'" matrix="1 0 0 1 -232 -174.399" transformations="translations" pos="32 96" stroke="black" type="minipage" width="2328" height="72.157" depth="67.34" valign="top" size="20">\begin{enumerate}
\item G. Brückner, I. Rutter, and P. Stumpf. Level-Planarity: Transitivity vs. Even Crossings. \textit{Electron. J. Comb.}, 29(4), 2022.

\item M. Harrigan, P. Healy, Practical level planarity testing and layout with embedding constraints. \textit{Graph Drawing &apos;07,  Lecture Notes in Computer Science}, 4875:62-68, 2007.

\item P. Healy, A. Kuusik, Algorithms for multi-level graph planarity testing and layout. \textit{Theor. Comput. Sci.} 320(2–3):331–344, 2004.


\item M. Jünger, S. Leipert, Level planar embedding in linear time. \textit{J. Graph Algorithm. Appl}. 6(1):67–113, 2002.

\item M. Jünger, S. Leipert, P. Mutzel, Level planarity testing in linear time,\textit{Graph Drawing, Lecture Notes in Computer Science}, 1547:224–237, 1998.



\item  B. Randerath,  E. Speckenmeyer,  E Boros,  P. L. Hammer,  A. Kogan, K. Makino, B. Simeone, and O. Cepek.
A satisfiability formulation  of  problems  on  level  graphs.
\textit{Electron.  Notes  Discret.  Math.},  9:269–277, 2001.

\end{enumerate}
</text>
