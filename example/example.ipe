<group layer="alpha">
<text matrix="1 0 0 1 32 -44" pos="0 524" stroke="black" type="label" width="237.868" height="19.0624" depth="0" valign="baseline">\probname{Level Planarity}</text>
<text matrix="1 0 0 1 124 -31.203" transformations="translations" pos="0 471.203" stroke="black" type="label" width="220.648" height="20.9244" depth="6.972" valign="baseline">Graph $G = (V, E)$,</text>
<text matrix="1 0 0 1 124 -99.203" transformations="translations" pos="0 471.203" stroke="black" type="label" width="279.51" height="19.3928" depth="5.404" valign="baseline">planar drawing $\Gamma_G$ of $G$</text>
<text matrix="1 0 0 1 32 -31.203" transformations="translations" pos="0 471.203" stroke="black" type="label" width="79.968" height="19.3704" depth="0" valign="baseline">\textbf{Given:}</text>
<text matrix="1 0 0 1 32 -99.203" transformations="translations" pos="0 471.203" stroke="black" type="label" width="78.2236" height="19.3704" depth="0" valign="baseline">\textbf{Want:}</text>
<text matrix="1 0 0 1 124 -129.203" transformations="translations" pos="0 471.203" stroke="black" type="label" width="248.763" height="19.3928" depth="5.404" valign="baseline">using y-coordinates $\gamma$</text>
